{
  "redirects": [
    {
      "source": "/flujo del sistema/:path*",
      "destination": "/anexo-tecnico/:path*",
      "permanent": true
    },
    {
      "source": "/flujo%20del%20sistema/:path*",
      "destination": "/anexo-tecnico/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/arquitectura",
      "destination": "/anexo-tecnico/anexo6/Arquitectura y flujo.html"
    },
    {
      "source": "/sagest.css",
      "destination": "/anexo-tecnico/anexo6/sagest.css"
    },
    {
      "source": "/sagest.js",
      "destination": "/anexo-tecnico/anexo6/sagest.js"
    }
  ]
}
